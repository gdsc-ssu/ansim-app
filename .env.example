# .env 파일을 이 템플릿 기반으로 생성하세요.
# iOS 빌드 시 ios/Runner/.env 심볼릭 링크도 필요합니다:
#   ln -sf ../../.env ios/Runner/.env

base_url="https://your-api-server-url/"
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

CLIENT_ID="your-google-oauth-client-id"
REVERSED_CLIENT_ID="your-reversed-client-id"
WEB_CLIENT_ID="your-web-client-id"
